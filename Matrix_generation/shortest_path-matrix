import networkx as nx
import numpy as np
import pickle

with open("./board_graph.pkl", "rb") as f:
    board = pickle.load(f)

N_NODES = 200  # Nodi "1"-"199", indici 0-198; indice 199 non usato

TICKET_TYPES = ["taxi", "bus", "underground"]

def edge_types_for_index(idx):
    types = set()
    if idx & 1:
        types.add("taxi")
    if idx & 2:
        types.add("bus")
    if idx & 4:
        types.add("underground")
    return types

def build_subgraph(graph, allowed_types):
    sub = nx.MultiGraph()
    sub.add_nodes_from(graph.nodes())
    for u, v, data in graph.edges(data=True):
        if data["type"] in allowed_types:
            sub.add_edge(u, v, **data)
    return sub

def generate_tensor():
    tensor = np.full((8, N_NODES, N_NODES), 999, dtype=np.int16)

    for idx in range(8):
        allowed = edge_types_for_index(idx)
        if not allowed:
            continue

        sub = build_subgraph(board, allowed)
        distances = dict(nx.all_pairs_shortest_path_length(sub))

        for i in range(1, N_NODES):
            src = str(i)
            if src not in distances:
                continue
            src_distances = distances[src]
            for j in range(1, N_NODES):
                dst = str(j)
                if dst in src_distances:
                    tensor[idx][i - 1][j - 1] = src_distances[dst]

    np.save("./distanze_scotland_yard_3d.npy", tensor)
    print(f"Saved tensor with shape {tensor.shape}")

if __name__ == "__main__":
    generate_tensor()
